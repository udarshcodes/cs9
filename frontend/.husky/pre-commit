# Husky pre-commit hook: enforce ESLint on staged files.
# Auto-installed via the frontend "prepare" script on `npm install`.
# Lints staged frontend (js/jsx/ts/tsx) and backend (js) files independently, so
# a commit touching only one side isn't slowed by the other.
# Bypass in emergencies with: git commit --no-verify

changed=$(git diff --cached --name-only --diff-filter=ACMR)

# Staged (Added/Copied/Modified/Renamed) source files per workspace.
fe_staged=$(printf '%s\n' "$changed" | grep -E '^frontend/.*\.(js|jsx|ts|tsx)$' || true)
be_staged=$(printf '%s\n' "$changed" | grep -E '^backend/.*\.js$' || true)

[ -z "$fe_staged$be_staged" ] && exit 0

status=0

if [ -n "$fe_staged" ]; then
  # Strip the leading "frontend/" so paths are relative to the ESLint config root.
  fe_rel=$(printf '%s\n' "$fe_staged" | sed 's#^frontend/##')
  echo "▶ pre-commit: linting staged frontend file(s)…"
  # shellcheck disable=SC2086  # intentional word-splitting of the file list
  ( cd frontend && npx --no-install eslint $fe_rel ) || status=1
fi

if [ -n "$be_staged" ]; then
  # Strip the leading "backend/" so paths are relative to the ESLint config root.
  be_rel=$(printf '%s\n' "$be_staged" | sed 's#^backend/##')
  echo "▶ pre-commit: linting staged backend file(s)…"
  # shellcheck disable=SC2086  # intentional word-splitting of the file list
  ( cd backend && npx --no-install eslint $be_rel ) || status=1
fi

if [ "$status" -ne 0 ]; then
  echo ""
  echo "✖ ESLint failed. Fix the errors above (try: npx eslint --fix <files> in the"
  echo "  relevant workspace), re-stage, and commit again. Bypass: git commit --no-verify"
  exit 1
fi

echo "✓ pre-commit: lint passed."
